# ── Postgres (ADR-I5: two clients, always) ──────────────────────────────────
# Pooled via PgBouncer (:6432, transaction pooling) — EVERY runtime query.
# SqlLive sets prepare:false / fetchTypes:false because transaction pooling
# invalidates server-side prepared statements.
POSTGRES_URL=postgresql://postgres:postgres@localhost:6432/catalog
# Direct (:5432, session mode) — DDL / migrations ONLY (SqlAdmin, migrate.ts).
POSTGRES_ADMIN_URL=postgresql://postgres:postgres@localhost:5432/catalog

# ── AI providers (Phase 2 extract / Phase 5 answer) ─────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Extraction model (Phase 2). Config knob + §11.5 ablation seam. Default below.
#   claude-haiku-4-5   # default — cheapest; the doc's "Haiku-class" budget
#   claude-sonnet-4-6  # accuracy/cost midpoint
#   claude-opus-4-8    # precision run
EXTRACTION_MODEL=claude-haiku-4-5

# Gemini batch extractor (pnpm --filter @catalog/server extract:batch) — the cheap-
# tier §11.5 candidate: native JSON-schema output + Batch API (~50% off, async).
# Optional knobs: GEMINI_EXTRACTION_MODEL (default gemini-2.5-flash-lite),
# GEMINI_BATCH_POLL_SECONDS (20), GEMINI_BATCH_MAX_MINUTES (180).
GEMINI_API_KEY=

# ── HTTP ────────────────────────────────────────────────────────────────────
PORT=3000

# ── OpenTelemetry (§12 telemetry skeleton) ──────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── Phase 1 crawl (§6) ──────────────────────────────────────────────────────
# The catalog index discovered for detail links (a.chart → courseDisplay.cfm).
CECC_INDEX_URL=https://ce-catalog.rutgers.edu/searchResults.cfm?searchId=1
# Optional run knobs (pnpm --filter @catalog/server crawl):
#   CRAWL_LIMIT=10          # cap seeds for a bounded sample run
#   CRAWL_CONCURRENCY=4     # parallel fetches
#   CRAWL_DELAY_MS=250      # polite min delay per fetch per worker
#   BENCH_N=12              # sample size for `benchmark:fetch` (ADR-002)
