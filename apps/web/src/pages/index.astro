---
// The product surface (architecture.md §10.5). Server-rendered shell; one vanilla-TS
// island (lib/app.ts) drives the chat, editable chips (§10.2), zero-result relaxation
// (§10.3), live-hydrated cards with freshness (§10.4), and feedback (§5.5). Every fact
// on screen was hydrated from Postgres by the server — the model chose rows, not values.
const examples = [
  "evening cybersecurity courses in Newark under $2000",
  "online grant writing classes",
  "what math courses are open for registration?",
  "does the astrophysics course run every year?",
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Almanac — course catalog chat</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <main>
      <header class="masthead">
        <div class="masthead-top">
          <h1>Almanac</h1>
          <a
            class="gh-link"
            href="https://github.com/Handfish/AlmanacRAG"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="View source on GitHub"
            title="View source on GitHub"
          >
            <svg viewBox="0 0 16 16" width="24" height="24" aria-hidden="true" fill="currentColor">
              <path
                d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"
              ></path>
            </svg>
          </a>
        </div>
        <p class="tagline">
          The model chooses rows. The database speaks the facts. Prices, dates, and seat
          status are read live from Postgres at render — never retyped by the assistant.
        </p>
      </header>

      <form id="ask" autocomplete="off">
        <input
          id="q"
          name="q"
          type="text"
          placeholder="Ask about the catalog — e.g. “evening courses in Newark under $2,000”"
          aria-label="Ask about the catalog"
        />
        <button id="ask-btn" type="submit">Ask</button>
      </form>
      <div id="status-line" role="status" aria-live="polite"></div>

      <div class="examples">
        <span>Examples:</span>
        {examples.map((ex) => <button class="example" type="button" data-ask={ex}>{ex}</button>)}
      </div>

      <!-- Prominent cold-start banner. Shown by lib/app.ts on page load while the API
           container is booting (Cloud Run scales to zero, §10.5) — a signal the user can't
           miss, unlike the sub-second status-line flip. Hidden until app.ts reveals it. -->
      <div id="wake-banner" role="status" aria-live="polite" aria-hidden="true">
        <span class="wake-flake" aria-hidden="true">❄</span>
        <span class="wake-text">
          <strong>Waking the server…</strong> It was asleep to save resources. Your first
          question can take up to a minute — go ahead and type it now; it&rsquo;ll run as
          soon as the server is up.
        </span>
      </div>

      <section id="answer" aria-live="polite"></section>
    </main>

    <footer class="site-footer">
      <span>Built by Kenneth Udovic</span>
      <a
        href="https://github.com/Handfish/AlmanacRAG"
        target="_blank"
        rel="noopener noreferrer"
      >Source on GitHub</a>
    </footer>

    <script>
      import { boot } from "../lib/app";
      boot();
    </script>
  </body>
</html>
