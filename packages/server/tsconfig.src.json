{
  "extends": "../../tsconfig.base.json",
  "include": ["src"],
  "exclude": ["src/**/*.test.ts"],
  "references": [{ "path": "../domain" }],
  "compilerOptions": {
    "types": ["node"],
    "esModuleInterop": true,
    "outDir": "build/src",
    "tsBuildInfoFile": ".tsbuildinfo/src.tsbuildinfo",
    "rootDir": "src",
    "paths": {
      "@/*": ["${configDir}/src/*"],
      "@catalog/domain/*": ["../domain/src/*.js"]
    }
  }
}
